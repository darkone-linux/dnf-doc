---
// Liste automatiquement les pages situées dans un dossier donné
// (feuilles directes, hors page d'accueil). Trié par sidebar.order puis titre.
// Sans prop `dir` : liste le dossier de la page courante (sommaires how-to).
// Avec prop `dir` : liste le sous-dossier relatif indiqué.
import { getCollection } from "astro:content";

interface Props {
  dir?: string;
}
const { dir: subdir } = Astro.props;

const route = Astro.locals.starlightRoute;
const pageDir = route.entry.id.replace(/\/index$/, "");
const dir = subdir ? pageDir + "/" + subdir : pageDir;

const pages = (await getCollection("docs"))
  .filter((e) => {
    if (!e.id.startsWith(dir + "/")) return false;
    const rel = e.id.slice(dir.length + 1);
    return rel.length > 0 && !rel.includes("/") && rel !== "index";
  })
  .sort((a, b) => {
    const oa = a.data.sidebar?.order ?? Number.MAX_SAFE_INTEGER;
    const ob = b.data.sidebar?.order ?? Number.MAX_SAFE_INTEGER;
    return oa - ob || a.data.title.localeCompare(b.data.title);
  });
---

<ul>
  {
    pages.map((p) => (
      <li>
        <a href={`/${p.id}/`}>{p.data.title}</a>
      </li>
    ))
  }
</ul>
